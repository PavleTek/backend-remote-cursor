PORT=3847
AGENT_PATH=agent

# Deployed frontend URL (no trailing slash). Used to build the phone connect link.
FRONTEND_BASE_URL=https://your-app.up.railway.app

# Set to true to skip ngrok + QR on startup (local dev without tunnel)
# SKIP_NGROK=true

# Set to true to skip opening QR in Preview
# SKIP_QR=true

# NGROK_BIN=ngrok

# Optional path for favorite models JSON (default: data/favorite-models.json)
# FAVORITE_MODELS_PATH=/path/to/favorite-models.json

# Optional path for workspace overrides JSON (default: data/workspaces.json)
# WORKSPACES_CONFIG_PATH=/path/to/workspaces.json

# Optional path for connect QR PNG (default: data/connect-qr.png, overwritten each start)
# QR_CODE_PATH=/path/to/connect-qr.png
